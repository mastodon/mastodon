## Multiple servers can be added to the reverse_proxy. 
## Example: reverse_proxy 192.168.1.1:3000 92.168.1.2:3000  92.168.1.3:3000 {

(instance1_backend) {
        reverse_proxy 192.168.x.x:3000 {
                lb_policy least_conn
                fail_duration 30s
                max_fails 3
                header_up Host {host}
                header_up X-Real-IP {remote_host}
                header_up Proxy ""
                transport http {
                        read_timeout 3600s
                        response_header_timeout 3600s
                }
        }
}

(instance1_backend_streaming) {
        reverse_proxy 192.168.x.x:4000 {
                lb_policy least_conn
                fail_duration 30s
                max_fails 3
                header_up Proxy ""
        }
}

mastodon.instance.com {
        encode {
                zstd
                gzip 6
                minimum_length 1024
        }

        header ?Strict-Transport-Security "max-age=63072000; includeSubDomains;"
        header ?X-Content-Type-Options nosniff

        # Fingerprinted build output — filename changes on every rebuild, so cache forever
        @fingerprinted path /assets/* /packs/*
        handle @fingerprinted {
                header Cache-Control "public, max-age=2419200, immutable"
                import instance1_backend
        }

        # Replaceable static content — long cache but force a revalidate
        @static_assets path /avatars/* /emoji/* /headers/* /ocr/* /shortcuts/* /sounds/*
        handle @static_assets {
                header Cache-Control "public, max-age=2419200, must-revalidate"
                import instance1_backend
        }

        handle /sw.js {
                header Cache-Control "public, max-age=604800, must-revalidate"
                import instance1_backend
        }

        handle /system/* {
                header Cache-Control "public, max-age=2419200, immutable"
                header Content-Security-Policy "default-src 'none'; form-action 'none'"
                import instance1_backend
        }

        handle /api/v1/streaming* {
                import instance1_backend_streaming
        }
        handle {
                import instance1_backend
        }
}
